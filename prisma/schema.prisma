datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum AccountType {
  personal
  business
}

enum ReplyProfileType {
  personal
  business
}

enum ChannelType {
  email
  sms
}

enum ChannelProvider {
  google
  microsoft
  twilio
}

enum MessageDirection {
  inbound
  outbound
}

enum DraftStatus {
  none
  proposed
  approved
  sent
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum AgentJobStatus {
  pending
  running
  completed
  failed
}

enum CalendarHoldStatus {
  held
  confirmed
  cancelled
  expired
}

enum ConversationStatus {
  needs_reply
  in_progress
  closed
}

model Tenant {
  id                        String                      @id @default(cuid())
  name                      String                      @unique
  accountType               AccountType                 @default(business)
  createdAt                 DateTime                    @default(now())
  users                     User[]
  channels                  Channel[]
  conversations             Conversation[]
  contacts                  Contact[]
  auditLogs                 AuditLog[]
  googleCalendarCredentials GoogleCalendarCredential[]
  mindBodyCredential        MindBodyCredential?
  businessProfile           BusinessProfile?
  personalProfile           PersonalProfile?
  learnedReplyProfiles      LearnedReplyProfile[]
  aiUsageEvents             AiUsageEvent[]
  knowledgeDocuments        KnowledgeDocument[]
  approvalRequests          ApprovalRequest[]
  agentJobs                 AgentJob[]
  calendarHolds             CalendarHold[]
  conversationStates        ConversationState[]
  inboxTasks                InboxTask[]
  leads                     Lead[]
  personMemories            PersonMemory[]
  followUpSetting           FollowUpSetting?
  autopilotSetting          AutopilotSetting?
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  auditLogs        AuditLog[]
  approvalRequests ApprovalRequest[]
}

model Channel {
  id           String          @id @default(cuid())
  tenantId     String
  type         ChannelType     @default(email)
  provider     ChannelProvider @default(google)
  emailAddress String?         @unique
  createdAt    DateTime        @default(now())
  tenant                   Tenant           @relation(fields: [tenantId], references: [id])
  conversations            Conversation[]
  gmailCredential          GmailCredential?
  outlookCredential        OutlookCredential?
  learnedReplyProfiles     LearnedReplyProfile[]
}

model GmailCredential {
  id                    String    @id @default(cuid())
  channelId             String    @unique
  accessTokenEncrypted  String
  refreshTokenEncrypted String
  tokenExpiry           DateTime?
  historyId             String?
  lastSyncedAt          DateTime?
  lastSyncError         String?
  createdAt             DateTime  @default(now())
  channel               Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model OutlookCredential {
  id                    String    @id @default(cuid())
  channelId             String    @unique
  accessTokenEncrypted  String
  refreshTokenEncrypted String
  tokenExpiry           DateTime?
  lastSyncedAt          DateTime?
  lastSyncError         String?
  createdAt             DateTime  @default(now())
  channel               Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model MindBodyCredential {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  siteId            String
  usernameEncrypted String
  passwordEncrypted String
  createdAt         DateTime @default(now())
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model GoogleCalendarCredential {
  id                    String    @id @default(cuid())
  tenantId              String
  email                 String
  accessTokenEncrypted  String
  refreshTokenEncrypted String
  tokenExpiry           DateTime?
  createdAt             DateTime  @default(now())
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
}

model Contact {
  id            String         @id @default(cuid())
  tenantId      String
  name          String
  phoneE164     String
  createdAt     DateTime       @default(now())
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  conversations Conversation[]
  personMemory  PersonMemory?

  @@unique([tenantId, phoneE164])
}

model PersonMemory {
  id              String    @id @default(cuid())
  tenantId        String
  contactId       String    @unique
  lastContactAt   DateTime?
  messageCount    Int       @default(0)
  summary         String?
  preferences     String?
  openQuestions   String?
  promisedActions String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact         Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Conversation {
  id               String             @id @default(cuid())
  tenantId         String
  channelId        String
  externalThreadId String
  contactId        String?
  label            String?
  status           ConversationStatus @default(needs_reply)
  lastMessageAt    DateTime           @default(now())
  createdAt        DateTime           @default(now())
  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  channel          Channel            @relation(fields: [channelId], references: [id])
  contact          Contact?           @relation(fields: [contactId], references: [id])
  messages         Message[]
  draft            Draft?
  approvalRequests ApprovalRequest[]
  agentJobs        AgentJob[]
  calendarHolds    CalendarHold[]
  stateRecord      ConversationState?
  inboxTasks       InboxTask[]
  leads            Lead[]

  @@unique([tenantId, channelId, externalThreadId])
  @@index([tenantId, lastMessageAt])
}

model Message {
  id                String           @id @default(cuid())
  conversationId    String
  direction         MessageDirection
  fromE164          String
  toE164            String
  body              String
  providerMessageId String
  createdAt         DateTime         @default(now())
  conversation      Conversation     @relation(fields: [conversationId], references: [id])

  @@unique([providerMessageId])
  @@index([conversationId, createdAt])
}

model Draft {
  id             String      @id @default(cuid())
  conversationId String      @unique
  text           String
  status         DraftStatus @default(none)
  metadataJson   Json?
  createdAt      DateTime    @default(now())
  updatedAt        DateTime         @updatedAt
  conversation     Conversation     @relation(fields: [conversationId], references: [id])
  approvalRequests ApprovalRequest[]
}

model BusinessProfile {
  id               String   @id @default(cuid())
  tenantId         String   @unique
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  businessName     String
  industry         String   @default("med_spa")
  timezone         String   @default("America/New_York")
  defaultTone      String   @default("professional")
  businessHoursJson Json?
  bookingPolicy            String?
  escalationPolicy         String?
  primaryCalendarEmail     String?
  serviceDurationMinutes   Int      @default(60)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model KnowledgeDocument {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title      String
  content    String
  sourceType String   @default("faq")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  action      String
  payloadJson Json
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
}

model ConversationState {
  id             String   @id @default(cuid())
  tenantId       String
  conversationId String   @unique
  state          String
  priority       String
  reason         String
  nextAction     String
  confidence     Float    @default(0)
  source         String   @default("deterministic")
  metadataJson   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId, state])
  @@index([tenantId, priority])
}

model InboxTask {
  id                  String    @id @default(cuid())
  tenantId            String
  conversationId      String
  title               String
  status              String    @default("open")
  dueAt               DateTime?
  source              String    @default("deterministic")
  sourceMessageId     String?
  deterministicKey    String
  metadataJson        Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  tenant              Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation        Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, deterministicKey])
  @@index([tenantId, status])
  @@index([tenantId, dueAt])
  @@index([conversationId])
}

model Lead {
  id               String   @id @default(cuid())
  tenantId         String
  conversationId   String
  name             String
  company          String?
  need             String
  urgency          String   @default("medium")
  budgetClue       String?
  contactInfo      String?
  nextAction       String
  score            Int      @default(0)
  scoreExplanation String?
  estimatedValue   Int?
  scoredAt         DateTime?
  stage            String   @default("new")
  source           String   @default("deterministic")
  metadataJson     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, conversationId])
  @@index([tenantId, stage])
  @@index([tenantId, score])
}

model ApprovalRequest {
  id             String         @id @default(cuid())
  tenantId       String
  conversationId String
  agentJobId     String?
  draftId        String?
  status         ApprovalStatus @default(pending)
  reviewerUserId String?
  decisionNote   String?
  createdAt      DateTime       @default(now())
  decidedAt      DateTime?
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  conversation   Conversation   @relation(fields: [conversationId], references: [id])
  agentJob       AgentJob?      @relation(fields: [agentJobId], references: [id])
  draft          Draft?         @relation(fields: [draftId], references: [id])
  reviewer       User?          @relation(fields: [reviewerUserId], references: [id])

  @@index([tenantId, createdAt])
  @@index([conversationId])
}

model AgentJob {
  id               String          @id @default(cuid())
  tenantId         String
  conversationId   String
  trigger          String
  status           AgentJobStatus  @default(pending)
  intent           String?
  confidence       Float?
  requiresApproval Boolean         @default(true)
  slotsJson        Json?
  error            String?
  createdAt        DateTime        @default(now())
  startedAt        DateTime?
  completedAt      DateTime?
  tenant           Tenant          @relation(fields: [tenantId], references: [id])
  conversation     Conversation    @relation(fields: [conversationId], references: [id])
  toolCalls        AgentToolCall[]
  approvalRequests ApprovalRequest[]

  @@index([tenantId, createdAt])
  @@index([conversationId])
}

model AgentToolCall {
  id          String    @id @default(cuid())
  agentJobId  String
  toolName    String
  inputJson   Json
  outputJson  Json?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  agentJob    AgentJob  @relation(fields: [agentJobId], references: [id], onDelete: Cascade)

  @@index([agentJobId])
}

model CalendarHold {
  id              String             @id @default(cuid())
  tenantId        String
  conversationId  String
  calendarEmail   String
  externalEventId String
  status          CalendarHoldStatus @default(held)
  startAt         DateTime
  endAt           DateTime
  expiresAt       DateTime
  createdAt       DateTime           @default(now())
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  conversation    Conversation       @relation(fields: [conversationId], references: [id])

  @@index([tenantId, status])
  @@index([conversationId])
  @@index([expiresAt, status])
}

model FollowUpSetting {
  id                          String   @id @default(cuid())
  tenantId                    String   @unique
  enabled                     Boolean  @default(false)
  staleAfterDays              Int      @default(3)
  maxFollowUpsPerConversation Int      @default(2)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  tenant                      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AutopilotSetting {
  id                   String    @id @default(cuid())
  tenantId             String    @unique
  enabled              Boolean   @default(false)
  confidenceThreshold  Float     @default(0.85)
  allowedIntentsJson   Json?
  maxAutoSendsPerDay   Int       @default(10)
  disableAfterFailures Int       @default(3)
  currentFailures      Int       @default(0)
  disabledAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model LearnedReplyProfile {
  id                   String           @id @default(cuid())
  tenantId             String
  channelId            String?
  profileType          ReplyProfileType
  styleSummaryJson     Json
  exampleSnippetsJson  Json?
  sourceStatsJson      Json?
  promptVersion        String
  lastTrainedAt        DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  tenant               Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel              Channel?         @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([tenantId, profileType])
  @@index([channelId])
}

model AiUsageEvent {
  id              String   @id @default(cuid())
  tenantId        String
  feature         String
  model           String
  estimatedInputTokens  Int      @default(0)
  estimatedOutputTokens Int      @default(0)
  status          String
  createdAt       DateTime @default(now())
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([feature])
}

model PersonalProfile {
  id                      String    @id @default(cuid())
  tenantId                String    @unique
  toneSummary             String?
  greetingPatterns        String?
  signoffPatterns         String?
  sentenceLengthStyle     String?
  formalityLevel          String?
  recurringPhrasesToUse   String[]  @default([])
  recurringPhrasesToAvoid String[]  @default([])
  sanitizedExamples       String?
  sampleCount             Int       @default(0)
  lastTrainedAt           DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  tenant                  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}
