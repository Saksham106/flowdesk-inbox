datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum AccountType {
  personal
  business
}

enum ReplyProfileType {
  personal
  business
}

enum ChannelType {
  email
  sms
}

enum ChannelProvider {
  google
  microsoft
  twilio
}

enum MessageDirection {
  inbound
  outbound
}

enum DraftStatus {
  none
  proposed
  approved
  sent
}

enum ApprovalStatus {
  pending
  approved
  rejected
  cancelled
}

enum AgentJobStatus {
  pending
  running
  completed
  failed
}

enum CalendarHoldStatus {
  held
  confirmed
  cancelled
  expired
}

enum ConversationStatus {
  needs_reply
  in_progress
  closed
}

model Tenant {
  id                        String                      @id @default(cuid())
  name                      String                      @unique
  accountType               AccountType                 @default(business)
  createdAt                 DateTime                    @default(now())
  users                     User[]
  channels                  Channel[]
  conversations             Conversation[]
  contacts                  Contact[]
  auditLogs                 AuditLog[]
  googleCalendarCredentials GoogleCalendarCredential[]
  mindBodyCredential        MindBodyCredential?
  businessProfile           BusinessProfile?
  personalProfile           PersonalProfile?
  learnedReplyProfiles      LearnedReplyProfile[]
  aiUsageEvents             AiUsageEvent[]
  knowledgeDocuments        KnowledgeDocument[]
  approvalRequests          ApprovalRequest[]
  agentJobs                 AgentJob[]
  calendarHolds             CalendarHold[]
  conversationStates        ConversationState[]
  inboxTasks                InboxTask[]
  leads                     Lead[]
  valueSnapshots            ValueSnapshot[]
  personMemories            PersonMemory[]
  followUpSetting           FollowUpSetting?
  autopilotSetting          AutopilotSetting?
  vipContacts               VipContact[]
  snoozeReminders           SnoozeReminder[]
  emailAttachments          EmailAttachment[]
  aiBudget                  AiBudget?
  classificationCorrections ClassificationCorrection[]
  senderRules               SenderRule[]
  agentRules                AgentRule[]
  snippets                  Snippet[]
  gmailPushEvents           GmailPushEvent[]
  gmailWritebackQueue       GmailWritebackQueue[]
  outlookSyncEvents         OutlookSyncEvent[]
  schedulingSessions        SchedulingSession[]
  automationRuns            AutomationRun[]
  workflowTemplates         WorkflowTemplate[]
  workflowRuns              WorkflowRun[]
  googleDriveCredential     GoogleDriveCredential?
  gmailLabelMappings        GmailLabelMapping[]
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  auditLogs        AuditLog[]
  approvalRequests ApprovalRequest[]
}

model Channel {
  id           String          @id @default(cuid())
  tenantId     String
  type         ChannelType     @default(email)
  provider     ChannelProvider @default(google)
  emailAddress String?         @unique
  createdAt    DateTime        @default(now())
  tenant                   Tenant           @relation(fields: [tenantId], references: [id])
  conversations            Conversation[]
  gmailCredential          GmailCredential?
  outlookCredential        OutlookCredential?
  learnedReplyProfiles     LearnedReplyProfile[]
  gmailPushEvents          GmailPushEvent[]
  gmailWritebackQueue      GmailWritebackQueue[]
  outlookSyncEvents        OutlookSyncEvent[]
}

model GmailCredential {
  id                    String    @id @default(cuid())
  channelId             String    @unique
  accessTokenEncrypted  String
  refreshTokenEncrypted String
  tokenExpiry           DateTime?
  historyId             String?
  watchExpiresAt        DateTime?
  watchLastRenewalAttempt DateTime?
  watchRenewalError     String?
  lastHistoryFallbackAt DateTime?
  lastSyncedAt          DateTime?
  lastSyncMode          String?
  lastSyncStatus        String?
  lastSyncError         String?
  syncLockExpiresAt     DateTime?
  createdAt             DateTime  @default(now())
  channel               Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model GmailPushEvent {
  id          String    @id @default(cuid())
  tenantId    String
  channelId   String
  historyId   String?
  messageId   String    @unique
  status      String    @default("received")
  error       String?
  createdAt   DateTime  @default(now())
  processedAt DateTime?
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel     Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([tenantId, channelId])
  @@index([status])
}

model GmailWritebackQueue {
  id                     String   @id @default(cuid())
  tenantId               String
  channelId              String
  conversationId         String
  action                 String
  providerMessageIdsJson Json
  attempts               Int      @default(0)
  lastError              String?
  status                 String   @default("pending")
  nextAttemptAt          DateTime @default(now())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel                Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  conversation           Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, action])
  @@index([tenantId, status, nextAttemptAt])
}

// Per-tenant configuration for the canonical FlowDesk/* Gmail labels.
// A row exists only when the tenant has customized a label; absence means
// "enabled with the default (canonical) name".
model GmailLabelMapping {
  id          String   @id @default(cuid())
  tenantId    String
  canonical   String   // one of FLOWDESK_GMAIL_LABEL_NAMES
  displayName String?  // reserved for future in-Gmail rename; null = use canonical
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, canonical])
  @@index([tenantId])
}

model OutlookCredential {
  id                               String    @id @default(cuid())
  channelId                        String    @unique
  accessTokenEncrypted             String
  refreshTokenEncrypted            String
  tokenExpiry                      DateTime?
  deltaLinkEncrypted               String?
  subscriptionId                   String?   @unique
  subscriptionExpiresAt            DateTime?
  subscriptionClientStateEncrypted String?
  subscriptionLastRenewalAttempt   DateTime?
  subscriptionError                String?
  lastSyncedAt                     DateTime?
  lastSyncMode                     String?
  lastSyncStatus                   String?
  lastSyncError                    String?
  syncLeaseId                      String?
  syncLockExpiresAt                DateTime?
  createdAt                        DateTime  @default(now())
  channel                          Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model OutlookSyncEvent {
  id             String    @id @default(cuid())
  tenantId       String
  channelId      String
  notificationId String    @unique
  subscriptionId String
  resource       String
  changeType     String
  status         String    @default("pending")
  attempts       Int       @default(0)
  lastError      String?
  nextAttemptAt  DateTime  @default(now())
  createdAt      DateTime  @default(now())
  processedAt    DateTime?
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel        Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([tenantId, channelId])
}

model MindBodyCredential {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  siteId            String
  usernameEncrypted String
  passwordEncrypted String
  createdAt         DateTime @default(now())
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model GoogleCalendarCredential {
  id                    String    @id @default(cuid())
  tenantId              String
  email                 String
  accessTokenEncrypted  String
  refreshTokenEncrypted String
  tokenExpiry           DateTime?
  createdAt             DateTime  @default(now())
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
}

model Contact {
  id            String         @id @default(cuid())
  tenantId      String
  name          String
  phoneE164     String
  createdAt     DateTime       @default(now())
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  conversations Conversation[]
  personMemory  PersonMemory?

  @@unique([tenantId, phoneE164])
}

model PersonMemory {
  id              String    @id @default(cuid())
  tenantId        String
  contactId       String    @unique
  lastContactAt   DateTime?
  messageCount    Int       @default(0)
  summary         String?
  preferences     String?
  openQuestions   String?
  promisedActions String?
  source          String    @default("deterministic")
  contentHash     String?
  model           String?
  llmSyncedAt     DateTime?
  factsJson       Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact         Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Conversation {
  id               String             @id @default(cuid())
  tenantId         String
  channelId        String
  externalThreadId String
  contactId        String?
  label            String?
  status           ConversationStatus @default(needs_reply)
  userState        String?
  userStateSource  String?
  userStateUpdatedAt DateTime?
  readAt           DateTime?
  lastOpenedAt     DateTime?
  gmailUnread      Boolean            @default(false)
  gmailRawState    Json?
  lastMessageAt    DateTime           @default(now())
  createdAt        DateTime           @default(now())
  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  channel          Channel            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  contact          Contact?           @relation(fields: [contactId], references: [id])
  messages         Message[]
  draft            Draft?
  approvalRequests ApprovalRequest[]
  agentJobs        AgentJob[]
  calendarHolds    CalendarHold[]
  stateRecord      ConversationState?
  inboxTasks       InboxTask[]
  leads            Lead[]
  snoozeReminders  SnoozeReminder[]
  emailAttachments EmailAttachment[]
  gmailWritebacks  GmailWritebackQueue[]
  schedulingSession         SchedulingSession?
  automationRuns            AutomationRun[]
  workflowRuns              WorkflowRun[]

  @@unique([tenantId, channelId, externalThreadId])
  @@index([tenantId, lastMessageAt])
}

model Message {
  id                String           @id @default(cuid())
  conversationId    String
  direction         MessageDirection
  fromE164          String
  toE164            String
  body              String
  subject           String?
  providerMessageId String
  isRead            Boolean          @default(false)
  gmailLabelIds     Json?
  searchVector      Unsupported("tsvector")?
  createdAt         DateTime         @default(now())
  conversation      Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  emailAttachments  EmailAttachment[]

  @@unique([providerMessageId])
  @@index([conversationId, createdAt])
}

model Draft {
  id             String      @id @default(cuid())
  conversationId String      @unique
  text           String
  status         DraftStatus @default(none)
  metadataJson   Json?
  createdAt      DateTime    @default(now())
  updatedAt        DateTime         @updatedAt
  conversation     Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  approvalRequests ApprovalRequest[]
}

model BusinessProfile {
  id               String   @id @default(cuid())
  tenantId         String   @unique
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  businessName     String
  industry         String   @default("med_spa")
  timezone         String   @default("America/New_York")
  defaultTone      String   @default("professional")
  businessHoursJson Json?
  bookingPolicy            String?
  escalationPolicy         String?
  primaryCalendarEmail     String?
  serviceDurationMinutes   Int      @default(60)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model KnowledgeDocument {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title      String
  content    String
  sourceType String    @default("faq")
  sourceUrl  String?
  crawledAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([tenantId])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  action      String
  payloadJson Json
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
}

model ConversationState {
  id             String   @id @default(cuid())
  tenantId       String
  conversationId String   @unique
  state          String
  priority       String
  reason         String
  nextAction     String
  confidence     Float    @default(0)
  source         String   @default("deterministic")
  metadataJson   Json?
  attentionCategory String?
  emailType      String?
  isSalesLead    Boolean  @default(false)
  isSupport      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId, state])
  @@index([tenantId, priority])
  @@index([tenantId, attentionCategory])
  @@index([tenantId, isSalesLead])
  @@index([tenantId, isSupport])
}

model InboxTask {
  id                  String    @id @default(cuid())
  tenantId            String
  conversationId      String
  title               String
  status              String    @default("open")
  dueAt               DateTime?
  source              String    @default("deterministic")
  sourceMessageId     String?
  deterministicKey    String
  metadataJson        Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  tenant              Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation        Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, deterministicKey])
  @@index([tenantId, status])
  @@index([tenantId, dueAt])
  @@index([conversationId])
}

model Lead {
  id               String   @id @default(cuid())
  tenantId         String
  conversationId   String
  name             String
  company          String?
  need             String
  urgency          String   @default("medium")
  budgetClue       String?
  contactInfo      String?
  nextAction       String
  score            Int      @default(0)
  scoreExplanation String?
  estimatedValue   Int?
  scoredAt         DateTime?
  stage            String   @default("new")
  source           String   @default("deterministic")
  metadataJson     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, conversationId])
  @@index([tenantId, stage])
  @@index([tenantId, score])
}

model ValueSnapshot {
  id                    String   @id @default(cuid())
  tenantId              String
  weekEnding            DateTime
  draftsCreated         Int
  draftsSent            Int
  tasksExtracted        Int
  tasksClosed           Int
  leadsDetected         Int
  followUpsQueued       Int
  approvalsDecided      Int
  conversationsTriaged  Int
  estimatedMinutesSaved Int
  pipelineValue         Int
  updatedAt             DateTime @updatedAt
  createdAt             DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, weekEnding])
}

model ApprovalRequest {
  id             String         @id @default(cuid())
  tenantId       String
  conversationId String
  agentJobId     String?
  draftId        String?
  step           String         @default("send")
  status         ApprovalStatus @default(pending)
  reviewerUserId String?
  decisionNote   String?
  metadataJson   Json?
  createdAt      DateTime       @default(now())
  decidedAt      DateTime?
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agentJob       AgentJob?      @relation(fields: [agentJobId], references: [id])
  draft          Draft?         @relation(fields: [draftId], references: [id])
  reviewer       User?          @relation(fields: [reviewerUserId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, status, createdAt])
  @@index([conversationId])
}

model AgentJob {
  id               String          @id @default(cuid())
  tenantId         String
  conversationId   String
  trigger          String
  status           AgentJobStatus  @default(pending)
  intent           String?
  confidence       Float?
  requiresApproval Boolean         @default(true)
  slotsJson        Json?
  error            String?
  createdAt        DateTime        @default(now())
  startedAt        DateTime?
  completedAt      DateTime?
  tenant           Tenant          @relation(fields: [tenantId], references: [id])
  conversation     Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toolCalls        AgentToolCall[]
  approvalRequests ApprovalRequest[]

  @@index([tenantId, createdAt])
  @@index([conversationId])
}

model AgentToolCall {
  id          String    @id @default(cuid())
  agentJobId  String
  toolName    String
  inputJson   Json
  outputJson  Json?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  agentJob    AgentJob  @relation(fields: [agentJobId], references: [id], onDelete: Cascade)

  @@index([agentJobId])
}

model CalendarHold {
  id              String             @id @default(cuid())
  tenantId        String
  conversationId  String
  calendarEmail   String
  externalEventId String
  status          CalendarHoldStatus @default(held)
  startAt         DateTime
  endAt           DateTime
  expiresAt       DateTime
  createdAt       DateTime           @default(now())
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  conversation    Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([conversationId])
  @@index([expiresAt, status])
}

model FollowUpSetting {
  id                          String   @id @default(cuid())
  tenantId                    String   @unique
  enabled                     Boolean  @default(false)
  staleAfterDays              Int      @default(3)
  maxFollowUpsPerConversation Int      @default(2)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  tenant                      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AutopilotSetting {
  id                   String    @id @default(cuid())
  tenantId             String    @unique
  // Automation trust ladder (Level 0-5, see lib/agent/automation-level.ts).
  // Default 2 = "apply labels in Gmail" per product-direction.md; existing
  // tenants were backfilled by migration (enabled -> 5, otherwise 3).
  automationLevel      Int       @default(2)
  enabled              Boolean   @default(false)
  confidenceThreshold  Float     @default(0.85)
  allowedIntentsJson     Json?
  categoryThresholdsJson Json?
  maxAutoSendsPerDay   Int       @default(10)
  disableAfterFailures Int       @default(3)
  currentFailures      Int       @default(0)
  disabledAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model LearnedReplyProfile {
  id                   String           @id @default(cuid())
  tenantId             String
  channelId            String?
  profileType          ReplyProfileType
  styleSummaryJson     Json
  exampleSnippetsJson  Json?
  sourceStatsJson      Json?
  promptVersion        String
  lastTrainedAt        DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  tenant               Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel              Channel?         @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([tenantId, profileType])
  @@index([channelId])
}

model AiUsageEvent {
  id              String   @id @default(cuid())
  tenantId        String
  feature         String
  model           String
  estimatedInputTokens  Int      @default(0)
  estimatedOutputTokens Int      @default(0)
  estimatedCostUsd      Float    @default(0)
  status          String
  createdAt       DateTime @default(now())
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([feature])
}

model AiBudget {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  dailyLimitUsd   Float    @default(5.0)
  monthlyLimitUsd Float    @default(50.0)
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model PersonalProfile {
  id                      String    @id @default(cuid())
  tenantId                String    @unique
  toneSummary             String?
  greetingPatterns        String?
  signoffPatterns         String?
  sentenceLengthStyle     String?
  formalityLevel          String?
  recurringPhrasesToUse   String[]  @default([])
  recurringPhrasesToAvoid String[]  @default([])
  sanitizedExamples       String?
  sampleCount             Int       @default(0)
  lastTrainedAt           DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  tenant                  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model VipContact {
  id        String   @id @default(cuid())
  tenantId  String
  email     String
  domain    String?
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
}

model SnoozeReminder {
  id             String       @id @default(cuid())
  tenantId       String
  conversationId String
  userId         String
  snoozeUntil    DateTime
  reason         String?
  status         String       @default("pending")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, snoozeUntil])
  @@index([conversationId])
}

model EmailAttachment {
  id            String      @id @default(cuid())
  tenantId      String
  messageId     String
  conversationId String
  filename      String
  mimeType      String
  sizeBytes     Int?
  extractedText String?
  createdAt     DateTime    @default(now())
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  message       Message     @relation(fields: [messageId], references: [id], onDelete: Cascade)
  conversation  Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([messageId])
}

// Logs each manual attention correction so repeated patterns can be detected.
model ClassificationCorrection {
  id                String   @id @default(cuid())
  tenantId          String
  conversationId    String
  fromEmail         String
  fromDomain        String
  previousAttention String?
  newAttention      String
  createdAt         DateTime @default(now())
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, fromEmail, newAttention])
  @@index([tenantId, fromDomain, newAttention])
  @@index([tenantId, createdAt])
}

// A rule learned from repeated user corrections or manually created.
// status: "suggested" → awaiting user approval, "active" → applied automatically,
// "dismissed" → user declined.
model SenderRule {
  id              String   @id @default(cuid())
  tenantId        String
  matchType       String   // "email" | "domain"
  matchValue      String   // e.g. "tim@5by5.tv" or "beehiiv.com"
  targetAttention String   // e.g. "quiet", "read_later"
  status          String   @default("suggested")
  triggerCount    Int      @default(0)
  // Incremented on behavior-changing edits; executions record which version fired.
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, matchType, matchValue, targetAttention])
  @@index([tenantId, status])
}

model AgentRule {
  id            String   @id @default(cuid())
  tenantId      String
  plainText     String
  ruleType      String
  conditionsJson Json
  actionJson    Json
  status        String   @default("active")
  source        String   @default("plain_english")
  previewCount  Int?
  conflictsWith String?
  // Incremented on behavior-changing edits (conditions/action/plainText);
  // prior versions are snapshotted to AuditLog ("agent_rule.version_snapshot").
  version       Int       @default(1)
  // Set by the dry-run endpoint; draft rules cannot be enabled until a dry-run ran.
  lastDryRunAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

model Snippet {
  id            String   @id @default(cuid())
  tenantId      String
  title         String
  content       String
  useCount      Int      @default(0)
  status        String   @default("suggested")
  source        String   @default("mined")
  minedFromJson Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

model SchedulingSession {
  id               String       @id @default(cuid())
  tenantId         String
  conversationId   String       @unique
  status           String       @default("detecting")
  proposedTimesJson Json?
  confirmedTime    String?
  calendarEmail    String?
  eventId          String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

model AutomationRun {
  id                String       @id @default(cuid())
  tenantId          String
  conversationId    String
  trigger           String
  stepsJson         Json         @default("[]")
  status            String       @default("pending")
  approvalRequired  Boolean      @default(true)
  approvalRequestId String?
  rolledBackAt      DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  tenant            Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([conversationId])
}

model WorkflowTemplate {
  id        String        @id @default(cuid())
  tenantId  String
  name      String
  trigger   String
  stepsJson Json          @default("[]")
  enabled   Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  runs      WorkflowRun[]

  @@index([tenantId])
}

model WorkflowRun {
  id                 String           @id @default(cuid())
  tenantId           String
  workflowTemplateId String
  conversationId     String
  currentStep        Int              @default(0)
  status             String           @default("running")
  stateJson          Json?
  nextRunAt          DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template           WorkflowTemplate @relation(fields: [workflowTemplateId], references: [id], onDelete: Cascade)
  conversation       Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([nextRunAt])
  @@index([conversationId])
}

model GoogleDriveCredential {
  id                    String    @id @default(cuid())
  tenantId              String    @unique
  email                 String
  accessTokenEncrypted  String
  refreshTokenEncrypted String
  tokenExpiry           DateTime?
  createdAt             DateTime  @default(now())
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}
