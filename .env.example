DATABASE_URL="postgresql://flowdesk:flowdesk@localhost:5432/flowdesk_inbox?schema=public"
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me"
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
# The Twilio phone number in E.164 format that receives inbound SMS/calls
TWILIO_PHONE_NUMBER="+15551234567"

# Encryption key for storing Twilio auth tokens securely.
# Required in production — generate with: openssl rand -base64 32
# Optional in local dev (plaintext fallback with a warning).
ENCRYPTION_SECRET=""

# Base URL used for Twilio webhook callbacks (action URLs for voice calls).
# In dev: set to your ngrok URL (e.g. https://abc123.ngrok-free.app)
# In prod: set to your Railway/production domain (e.g. https://yourapp.up.railway.app)
PUBLIC_WEBHOOK_BASE_URL="https://your-ngrok-or-domain-here.app"

# Voice call forwarding — the real office phone to ring before auto-texting.
# Required for missed-call auto-text to work. E.164 format.
OFFICE_PHONE_NUMBER="+15559876543"

# The SMS sent to a caller when their call goes unanswered.
# Optional — defaults to a built-in message if not set.
MISSED_CALL_REPLY_TEXT="Sorry we missed your call! Reply here and we'll get back to you shortly."

# Optional seed overrides
SEED_EMAIL="owner@flowdesk-inbox.local"
SEED_PASSWORD="password123"
SEED_TENANT_NAME="Flowdesk Inbox"
