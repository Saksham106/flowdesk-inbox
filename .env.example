# =============================================================================
# Primary / Required
# =============================================================================

DATABASE_URL="postgresql://flowdesk:flowdesk@localhost:5432/flowdesk_inbox?schema=public"

NEXTAUTH_URL="http://localhost:3000"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me"

# AES-256 key for encrypting OAuth tokens. Required in production.
# Generate with: openssl rand -base64 32
ENCRYPTION_SECRET=""

# Google OAuth — used for Gmail and Google Calendar connectors.
# Create credentials at console.cloud.google.com → APIs & Services → Credentials.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OpenAI — used for AI draft suggestions.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4-mini"

# =============================================================================
# Optional
# =============================================================================

# MindBody source password from developers.mindbodyonline.com
MINDBODY_API_KEY=""

# =============================================================================
# Development seed
# =============================================================================

SEED_EMAIL="owner@flowdesk-inbox.local"
SEED_PASSWORD="password123"
SEED_TENANT_NAME="Flowdesk Inbox"

# =============================================================================
# Deferred / Not required for MVP
# Twilio/SMS — deferred pending A2P 10DLC compliance. Not required to run the MVP.
# =============================================================================

# TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_AUTH_TOKEN="your_twilio_auth_token"
# TWILIO_PHONE_NUMBER="+15551234567"
# PUBLIC_WEBHOOK_BASE_URL="https://your-ngrok-or-domain-here.app"
# OFFICE_PHONE_NUMBER="+15559876543"
# MISSED_CALL_REPLY_TEXT="Sorry we missed your call! Reply here and we'll get back to you shortly."
