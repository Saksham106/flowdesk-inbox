# =============================================================================
# Primary / Required
# =============================================================================

DATABASE_URL="postgresql://flowdesk:flowdesk@localhost:5433/flowdesk_inbox?schema=public"

NEXTAUTH_URL="http://localhost:3000"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me"

# AES-256 key for encrypting OAuth tokens. Required in production.
# Generate with: openssl rand -base64 32
ENCRYPTION_SECRET=""

# Google OAuth — used for Gmail and Google Calendar connectors.
# Create credentials at console.cloud.google.com → APIs & Services → Credentials.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft OAuth — used for the Outlook connector. The production NEXTAUTH_URL
# must be public HTTPS for Microsoft Graph change notifications.
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# Gmail push sync (optional in development, recommended in production)
GMAIL_PUSH_TOPIC=""
GMAIL_PUSH_SECRET=""
# Bearer secret for all scheduled endpoints, including Outlook delta sync.
CRON_SECRET=""

# OpenRouter — used for AI classification, rules, chat, and draft suggestions.
OPENROUTER_API_KEY=""
OPENROUTER_MANAGEMENT_API_KEY=""
OPENROUTER_MODEL="anthropic/claude-sonnet-4.5"
OPENROUTER_LEARNING_MODEL="anthropic/claude-haiku-4.5"
OPENROUTER_CHILD_KEY_MONTHLY_LIMIT_USD="10"
OPENROUTER_HTTP_REFERER="https://flowdeskinbox.com"
OPENROUTER_APP_TITLE="FlowDesk Inbox"

# =============================================================================
# Optional
# =============================================================================

# MindBody source password from developers.mindbodyonline.com
MINDBODY_API_KEY=""

# =============================================================================
# Development seed
# =============================================================================

SEED_EMAIL="owner@flowdesk-inbox.local"
SEED_PASSWORD="password123"
SEED_TENANT_NAME="Flowdesk Inbox"
